# ============================================================================
# octoprint2n8n bridge configuration
# Copy to `.env` and fill in. Only OCTOPRINT_URL and OCTOPRINT_API_KEY are
# strictly required; everything else has sensible defaults.
# ============================================================================

# --- OctoPrint (required) ---------------------------------------------------
# Base URL of your OctoPrint instance (no trailing /api).
OCTOPRINT_URL=http://octopi.local
# API key: OctoPrint → Settings → API, or Settings → Application Keys.
OCTOPRINT_API_KEY=
# Set to true to accept a self-signed TLS cert on OctoPrint.
OCTOPRINT_ALLOW_INSECURE_TLS=false

# --- n8n (events out) -------------------------------------------------------
# The Production webhook URL from your "OctoPrint Trigger" node.
# Leave blank to disable forwarding (commands-only mode).
N8N_WEBHOOK_URL=

# --- Bridge security + server ----------------------------------------------
# Shared secret. Authenticates the command API (Bearer) and HMAC-signs events.
# Must match the "Shared Secret" in the n8n OctoPrint Bridge credential.
# Generate one with:  openssl rand -hex 32
# If left blank: the command API is disabled and events are sent unsigned.
BRIDGE_SHARED_SECRET=
# Port + bind address for the bridge's HTTP API.
BRIDGE_PORT=5252
BRIDGE_BIND=0.0.0.0
# Identifier included in every event (defaults to the container hostname).
INSTANCE_ID=

# --- Event tuning -----------------------------------------------------------
# OctoPrint "current" push throttle, in units of 500ms (2 = ~1s). 0 = no throttle.
SOCKET_THROTTLE=2
# How often to poll OctoPrint for a Snapshot event, in ms. 0 disables polling.
POLL_INTERVAL_MS=30000
# Emit a Progress event when completion changes by at least this many percent...
PROGRESS_DELTA_PCT=1
# ...or at least this often (ms) while printing.
PROGRESS_MIN_INTERVAL_MS=30000
# Include the raw OctoPrint payload on each event (larger payloads).
INCLUDE_RAW=false

# --- Logging ----------------------------------------------------------------
# debug | info | warn | error
LOG_LEVEL=info
