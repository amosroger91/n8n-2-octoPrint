{
  "id": "OctoPrintDemo001",
  "name": "OctoPrint Demo",
  "nodes": [
    {
      "parameters": {
        "path": "octoprint",
        "events": ["*"],
        "verifySignature": false
      },
      "id": "11111111-1111-4111-8111-111111111111",
      "name": "OctoPrint Trigger",
      "type": "n8n-nodes-octoprint.octoPrintTrigger",
      "typeVersion": 1,
      "position": [420, 300],
      "webhookId": "octoprint-demo"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:9099/from-n8n",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {}
      },
      "id": "22222222-2222-4222-8222-222222222222",
      "name": "Forward to capture",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300],
      "onError": "continueRegularOutput"
    }
  ],
  "connections": {
    "OctoPrint Trigger": {
      "main": [[{ "node": "Forward to capture", "type": "main", "index": 0 }]]
    }
  },
  "active": true,
  "settings": { "executionOrder": "v1" }
}
