# ============================================================================
# print-orchestrator configuration. Copy to .env and fill in.
# ============================================================================

# --- Redis (the local job queue) -------------------------------------------
REDIS_URL=redis://127.0.0.1:6379

# --- OctoPrint (the printer this box drives) -------------------------------
OCTOPRINT_URL=http://192.168.1.156:5000
OCTOPRINT_API_KEY=
OCTOPRINT_ALLOW_INSECURE_TLS=false
# Identifier for this printer/box (defaults to hostname).
PRINTER_ID=

# --- Slicer (auto-slice STL -> gcode) --------------------------------------
# Full URL of the slice endpoint. Leave blank to require pre-sliced gcode.
SLICER_URL=https://slicer.wellspringstudiollc.com/slice
SLICER_USERNAME=
SLICER_PASSWORD=
# Printer profile the slicer should target.
SLICER_PROFILE=ender3v3se

# --- n8n queue (poll for jobs, push status) --------------------------------
# Webhook the orchestrator GETs to fetch queued jobs. Blank disables polling.
N8N_QUEUE_URL=
# Webhook the orchestrator POSTs status/progress updates to.
N8N_STATUS_URL=
# Optional Authorization header value for those webhooks (e.g. "Bearer xyz").
N8N_AUTH_HEADER=
N8N_POLL_INTERVAL_MS=10000

# --- Behaviour --------------------------------------------------------------
# Concurrent prints (keep at 1 — one nozzle).
CONCURRENCY=1
# How often to poll OctoPrint for print progress, in ms.
PRINT_POLL_INTERVAL_MS=5000
# Safety cap on a single print, in ms (default 24h).
PRINT_TIMEOUT_MS=86400000
LOG_LEVEL=info
