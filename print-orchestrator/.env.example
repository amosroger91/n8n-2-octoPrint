# ============================================================================
# print-orchestrator configuration. Copy to .env and fill in.
# ============================================================================

# --- Redis (the local job queue) -------------------------------------------
REDIS_URL=redis://127.0.0.1:6379

# --- OctoPrint (the printer this box drives) -------------------------------
OCTOPRINT_URL=http://192.168.1.156:5000
OCTOPRINT_API_KEY=
OCTOPRINT_ALLOW_INSECURE_TLS=false
# Identifier for this printer/box (defaults to hostname).
PRINTER_ID=

# --- Slicer (auto-slice STL -> gcode) --------------------------------------
# When you run `docker compose up`, the bundled headless-OrcaSlicer `slicer`
# service is used automatically (SLICER_URL defaults to http://slicer:8080/slice)
# — leave this BLANK for that. Set it only to point at a different/external slice
# endpoint instead. Blank + no bundled slicer => jobs must already be gcode.
# See print-orchestrator/README.md for the request/response contract.
SLICER_URL=
# Only needed if your external slice endpoint is behind HTTP basic-auth.
SLICER_USERNAME=
SLICER_PASSWORD=
# Printer profile hint passed to the slicer (the bundled slicer targets the
# Ender 3 V3 SE 0.4mm by default; override its MACHINE_MATCH/PROCESS_MATCH env).
SLICER_PROFILE=ender3v3se

# --- Object store (any S3-compatible bucket) --------------------------------
# Where the form stages STL/gcode. The orchestrator downloads a job's source
# from here and DELETES it once it's on OctoPrint. Works with MinIO, AWS S3,
# Cloudflare R2, Backblaze B2, Garage, etc. Leave S3_ENDPOINT blank to disable
# (sources are then plain http(s) URLs).
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=print-staging
S3_REGION=us-east-1
# true for MinIO / most self-hosted; false for AWS-style virtual-host buckets.
S3_FORCE_PATH_STYLE=true

# --- n8n queue (poll for jobs, push status) --------------------------------
# Webhook the orchestrator GETs to fetch queued jobs. Blank disables polling.
N8N_QUEUE_URL=
# Webhook the orchestrator POSTs status/progress updates to.
N8N_STATUS_URL=
# Optional Authorization header value for those webhooks (e.g. "Bearer xyz").
N8N_AUTH_HEADER=
N8N_POLL_INTERVAL_MS=10000

# --- Behaviour --------------------------------------------------------------
# Concurrent prints (keep at 1 — one nozzle).
CONCURRENCY=1
# How often to poll OctoPrint for print progress, in ms.
PRINT_POLL_INTERVAL_MS=5000
# Safety cap on a single print, in ms (default 24h).
PRINT_TIMEOUT_MS=86400000
# SSRF guard for STL/gcode fetches: only http/https + never cloud-metadata are
# always enforced. Print farms are usually on a LAN, so private addresses are
# allowed by default — set false to restrict fetches to public hosts only.
ALLOW_PRIVATE_FETCH=true
LOG_LEVEL=info

# --- Dashboard + auth -------------------------------------------------------
DASHBOARD_ENABLED=true
DASHBOARD_PORT=4848
DASHBOARD_USERNAME=admin
# Blank => a random password is generated and printed in the logs on startup.
DASHBOARD_PASSWORD=
# Signs login sessions. Blank => ephemeral (logins drop on restart).
# Generate a stable one with:  openssl rand -hex 32
SESSION_SECRET=
